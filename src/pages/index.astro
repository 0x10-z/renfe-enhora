---
import Layout from "../layouts/Layout.astro";
import StatCard from "../components/StatCard.astro";
import InsightModal from "../components/modals/InsightModal.astro";
import StationModal from "../components/modals/StationModal.astro";
import TrainViewerModal from "../components/modals/TrainViewerModal.astro";
import TrainTypeDetailModal from "../components/modals/TrainTypeDetailModal.astro";
---

<Layout title="Tablero de Llegadas">
  <div class="page-header">
    <div>
      <h1>Tablero de Llegadas</h1>
      <p class="subtitle">Renfe España · Próximos 60 minutos</p>
    </div>
    <div class="refresh-info">
      <span id="last-updated" class="muted">Cargando datos…</span>
      <div class="refresh-bar-wrap" title="Próxima actualización">
        <div id="refresh-bar" class="refresh-bar"></div>
      </div>
    </div>
  </div>

  <!-- Service tabs -->
  <div class="tabs" id="service-tabs" role="tablist">
    <button class="tab" data-svc="ave-larga-distancia" role="tab">AVE · Larga y Media Distancia</button>
    <button class="tab" data-svc="cercanias" role="tab">Cercanías</button>
  </div>

  <!-- Stats grid -->
  <div class="stats-grid">
    <StatCard
      valueId="v-total"
      label="Paradas analizadas"
      tip="Paradas con llegada programada en la ventana de 60 min siguiente al último análisis. Una misma línea suma una parada por estación."
    >
      <svg slot="icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      <div slot="sub" class="stat-sub" id="sub-stations">— estaciones</div>
    </StatCard>

    <StatCard
      valueId="v-delayed"
      label="Con retraso"
      tip="Paradas con más de 5 min de retraso según el RT de Renfe en el momento del análisis"
      variant="warn"
    >
      <svg slot="icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div slot="sub" class="stat-sub" id="sub-pct">—% del total</div>
    </StatCard>

    <StatCard
      valueId="v-avg"
      label="Media de retraso"
      tip="Media de minutos de retraso calculada sobre las paradas con retraso en la última captura"
    >
      <svg slot="icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <div slot="sub" class="stat-sub" id="sub-avg"></div>
    </StatCard>

    <StatCard
      id="sc-max"
      valueId="v-max"
      label="Máximo retraso"
      tip="Mayor retraso individual registrado en la última captura horaria"
      variant="danger"
    >
      <svg slot="icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div slot="sub" class="stat-sub" id="sub-max"></div>
    </StatCard>

    <StatCard
      valueId="v-trips"
      label="Trenes en ruta"
      tip="Viajes únicos (trip_ids distintos) en la ventana de análisis. Representa el número real de trenes en circulación en ese momento."
    >
      <svg slot="icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16"/><path d="M12 3v8"/><circle cx="8.5" cy="17.5" r="1.5"/><circle cx="15.5" cy="17.5" r="1.5"/></svg>
      <div slot="sub" class="stat-sub" id="sub-trips">— estaciones activas</div>
    </StatCard>
  </div>

  <!-- Section switcher -->
  <div class="section-switcher" role="tablist">
    <button class="section-btn active" id="btn-analytics" data-section="analytics" role="tab" aria-selected="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Análisis
    </button>
    <button class="section-btn" id="btn-stations" data-section="stations" role="tab" aria-selected="false">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      Estaciones
    </button>
    <button class="section-btn" id="btn-map" data-section="map" role="tab" aria-selected="false">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
      Mapa
    </button>
  </div>

  <!-- Analytics section -->
  <div id="section-analytics">
    <section class="history-section" id="history-section" style="display:none">
      <div class="section-header">
        <h2>Histórico de retrasos</h2>
        <div class="range-btns" role="group">
          <button class="range-btn" data-days="7">7d</button>
          <button class="range-btn" data-days="30">30d</button>
          <button class="range-btn" data-days="90">90d</button>
          <button class="range-btn" data-days="0">Todo</button>
          <button class="range-btn active" data-days="-1">Por hora</button>
          <button class="range-btn" data-days="-2">Mapa de calor</button>
        </div>
      </div>
      <div class="chart-card">
        <div id="echart-main" style="height:220px;width:100%;transition:height 0.2s"></div>
      </div>
    </section>

    <section class="insights-section" id="insights-section" style="display:none">
      <div class="section-header">
        <h2>Observaciones</h2>
        <span class="count-badge" id="insight-count">—</span>
      </div>
      <div class="insights-grid" id="insights-grid"></div>
    </section>

    <section class="train-type-section" id="train-type-section" style="display:none">
      <div class="section-header">
        <h2>Por tipo de tren</h2>
        <button class="info-btn" id="train-type-info-btn" aria-label="Información sobre tipos de tren">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </button>
      </div>
      <div class="chart-card">
        <p id="train-type-narrative" class="train-type-narrative"></p>
        <div id="echart-train-type" style="width:100%"></div>
      </div>
    </section>

    <!-- Zones section -->
    <section class="zones-section" id="zones-section" style="display:none">
      <div class="section-header">
        <h2>Por comunidad autónoma</h2>
      </div>
      <div id="ccaa-map-container" class="ccaa-map-container"></div>
      <div class="ccaa-map-legend" id="ccaa-map-legend" aria-hidden="true">
        <span class="legend-item"><span class="legend-dot" style="background:#16a34a"></span>&lt;3%</span>
        <span class="legend-item"><span class="legend-dot" style="background:#65a30d"></span>3–10%</span>
        <span class="legend-item"><span class="legend-dot" style="background:#d97706"></span>10–20%</span>
        <span class="legend-item"><span class="legend-dot" style="background:#ea580c"></span>20–30%</span>
        <span class="legend-item"><span class="legend-dot" style="background:#dc2626"></span>&gt;30%</span>
        <span class="legend-item"><span class="legend-dot" style="background:#94a3b8;opacity:0.4"></span>Sin datos</span>
      </div>
      <div class="zones-grid" id="zones-ccaa-grid"></div>

      <div class="section-header" id="zones-nucleo-header" style="display:none; margin-top:1.2rem">
        <h2>Por núcleo de Cercanías</h2>
      </div>
      <div class="zones-grid" id="zones-nucleo-grid"></div>
    </section>
  </div>

  <!-- Train type info modal -->
  <div id="train-type-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true" aria-labelledby="train-type-modal-title">
    <div class="modal-panel train-type-modal-panel">
      <div class="modal-header">
        <div class="modal-title-wrap">
          <h2 id="train-type-modal-title">Tipos de tren en Renfe</h2>
        </div>
        <div class="modal-header-right">
          <button class="modal-close" id="train-type-modal-close" aria-label="Cerrar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>
      <div class="modal-body train-type-modal-body">
        <div class="tt-grid">

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-ave">AVE</span>
              <span class="tt-name">Alta Velocidad Española</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/ave/s112.webp" alt="AVE serie 112 – Siemens Velaro E" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Trenes de alta velocidad que circulan por vías exclusivas a más de 250 km/h. Son los más rápidos de la red y conectan las principales ciudades.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">100, 102, 103, 112, 114, 130</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Madrid–Barcelona, Madrid–Sevilla, Madrid–Valencia</span>
            </div>
          </div>

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-avlo">AVLO</span>
              <span class="tt-name">AVE Low Cost</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/avlo/s106.webp" alt="AVLO serie 106 – Talgo Avril" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Versión de bajo coste del AVE. Utiliza la misma infraestructura de alta velocidad pero con tarifas más reducidas y servicios más básicos a bordo.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">106 (Talgo Avril)</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Madrid–Barcelona, Madrid–Valencia</span>
            </div>
          </div>

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-alvia">Alvia</span>
              <span class="tt-name">Alta Velocidad + Larga Distancia</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/alvia/s120.webp" alt="Alvia serie 120" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Trenes de velocidad media-alta (hasta 250 km/h) que pueden circular tanto por vías de alta velocidad como por vías convencionales, gracias a su sistema de cambio de ancho. Esto les permite llegar a ciudades no conectadas directamente por la red AVE.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">120, 121, 130</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Madrid–Vigo, Madrid–A Coruña, Madrid–Bilbao</span>
            </div>
          </div>

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-avant">Avant</span>
              <span class="tt-name">AVE Regional de Corta Distancia</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/avant/s114.webp" alt="Avant serie 114" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Servicio de alta velocidad para trayectos cortos sobre la red de alta velocidad. Son más económicos que el AVE y sirven recorridos de menos de 200 km entre ciudades próximas.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">104, 114, 121</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Madrid–Toledo, Valladolid–Segovia, Sevilla–Córdoba</span>
            </div>
          </div>

          <div class="tt-card tt-card--highlight">
            <div class="tt-header">
              <span class="tt-badge tt-md">MD</span>
              <span class="tt-name">Media Distancia</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/md/s449.webp" alt="Media Distancia serie 449" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Trenes convencionales que conectan capitales de provincia y ciudades medianas. Circulan por vías convencionales a velocidades menores que el AVE. Su flota es más moderna que la Regional y cubre recorridos de entre 100 y 400 km.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">449, 450, 592, 594, 598</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Sevilla–Málaga, Valencia–Alicante, Barcelona–Lleida</span>
            </div>
          </div>

          <div class="tt-card tt-card--highlight">
            <div class="tt-header">
              <span class="tt-badge tt-reg">Regional</span>
              <span class="tt-name">Tren Regional</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/regional/s596.webp" alt="Regional serie 596" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Servicio regional de corta y media distancia que conecta poblaciones más pequeñas con capitales de provincia. Más paradas que Media Distancia, recorridos más cortos y velocidades más bajas. Suele usar material rodante más antiguo.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">592, 596, 598</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Burgos–Miranda, Huesca–Zaragoza, Cáceres–Badajoz</span>
            </div>
          </div>

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-ld">LD</span>
              <span class="tt-name">Larga Distancia</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/ld/s252.webp" alt="Larga Distancia – Talgo 252" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Trenes de largo recorrido en vías convencionales, con servicios nocturnos y diurnos. Incluye los Intercity y Talgo. Más lentos que el AVE pero con paradas en ciudades intermedias y tarifas más variadas.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">Talgo 200, 252, Intercity (449, 269)</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Rutas típicas</span>
              <span class="tt-value">Madrid–Cádiz, Barcelona–Vigo, trenes nocturnos</span>
            </div>
          </div>

          <div class="tt-card">
            <div class="tt-header">
              <span class="tt-badge tt-c">Cercanías</span>
              <span class="tt-name">Trenes de Cercanías</span>
            </div>
            <div class="tt-photo">
              <img src="/trenes/cercanias/s447.webp" alt="Cercanías serie 447" class="tt-train-img" loading="lazy" onerror="this.closest('.tt-photo').style.display='none'" />
            </div>
            <p class="tt-desc">Red de trenes de cercanías que conecta el núcleo urbano con los municipios del área metropolitana. Alta frecuencia, muchas paradas y recorridos cortos. Tarifas integradas con el transporte urbano en muchas ciudades.</p>
            <div class="tt-meta">
              <span class="tt-label">Series habituales</span>
              <span class="tt-value">440, 446, 447, 448, 450, 451, 463, 465, 470, 599</span>
            </div>
            <div class="tt-meta">
              <span class="tt-label">Núcleos</span>
              <span class="tt-value">Madrid, Barcelona, Valencia, Sevilla, Bilbao, Asturias, Murcia…</span>
            </div>
          </div>

          <div class="tt-callout">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p><strong>¿MD o Regional?</strong> La frontera no siempre es clara: la serie 592 aparece en ambos servicios según la comunidad autónoma. La diferencia práctica es que Media Distancia conecta capitales provinciales con recorridos de 100–400 km, mientras que Regional cubre distancias más cortas con más paradas intermedias y material más antiguo.</p>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Stations section -->
  <div id="section-stations" style="display:none">
    <div class="search-hero">
      <h2 class="search-hero-title">¿A qué estación vas?</h2>
      <p class="search-hero-sub">Busca entre <span id="station-count">—</span> estaciones de Renfe</p>
      <div class="search-wrap">
        <svg class="search-icon search-icon--hero" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input
          type="search"
          id="station-search"
          class="search-input search-input--hero"
          placeholder="Buscar estación…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
    </div>
    <div id="stations-list" class="stations-grid">
      <div class="skeleton-row"></div>
      <div class="skeleton-row"></div>
      <div class="skeleton-row"></div>
      <div class="skeleton-row"></div>
      <div class="skeleton-row"></div>
    </div>
    <div id="no-data" class="no-data" style="display:none">
      <p>Sin datos disponibles. El pipeline se ejecutará en breve.</p>
    </div>
  </div>

  <!-- Map section -->
  <div id="section-map" style="display:none">
    <div class="map-toolbar">
      <div class="map-mode-group" role="group" aria-label="Modo de visualización">
        <button class="map-mode-btn" data-mode="scatter">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="8" cy="8" r="3"/><circle cx="18" cy="5" r="2"/><circle cx="13" cy="17" r="4"/></svg>
          Burbujas
        </button>
        <button class="map-mode-btn active" data-mode="heat">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
          Calor
        </button>
      </div>
      <div class="map-legend">
        <span class="map-legend-dot map-legend-green"></span><span>A tiempo</span>
        <span class="map-legend-dot map-legend-yellow"></span><span>Retraso leve</span>
        <span class="map-legend-dot map-legend-red"></span><span>Retraso alto</span>
      </div>
    </div>
    <div class="map-card">
      <div id="map-container"></div>
      <div id="map-message" class="map-message" style="display:none"></div>
    </div>
  </div>

  <InsightModal />
  <StationModal />
  <TrainViewerModal />
  <TrainTypeDetailModal />

</Layout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .subtitle {
    color: var(--text-sub);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .refresh-info {
    text-align: right;
    font-size: 0.78rem;
  }

  .refresh-bar-wrap {
    width: 120px;
    height: 2px;
    background: var(--border);
    border-radius: 1px;
    margin-top: 0.5rem;
    overflow: hidden;
    margin-left: auto;
  }

  .refresh-bar {
    height: 100%;
    background: var(--accent);
    width: 100%;
    transform-origin: left;
    transition: transform linear;
  }

  /* Tabs */
  .tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }

  .tab {
    padding: 0.55rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    transition: color 0.15s, border-color 0.15s;
  }
  .tab:hover { color: var(--text); }
  .tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  @media (max-width: 1000px) {
    .stats-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 380px) {
    .stats-grid { grid-template-columns: 1fr; }
  }

  :global(.stat-unit) {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0;
    color: var(--text-muted);
    margin-left: 0.2em;
  }
  .stat-sub {
    font-size: 0.72rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Station list */
  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .section-header h2 {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .count-badge {
    font-size: 0.7rem;
    background: var(--accent-bg);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    font-family: var(--font-mono);
  }

  .search-wrap {
    position: relative;
    margin-bottom: 0.75rem;
  }
  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-sub);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.5rem;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-family: var(--font);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search-input::placeholder { color: var(--text-sub); }
  .search-input:focus {
    border-color: var(--accent-border);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }

  :global(.stations-grid) {
    display: grid;
    gap: 0.5rem;
  }

  /* Station card — rendered by JS */
  :global(.station-card) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.125rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: background 0.15s, border-color 0.15s;
    box-shadow: var(--shadow-sm);
  }
  :global(.station-card:hover) {
    background: var(--bg-card-hover);
    border-color: var(--border-bright);
    text-decoration: none;
  }
  :global(.station-dot) {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  }
  :global(.dot-green)  { background: var(--green); }
  :global(.dot-yellow) { background: var(--yellow); }
  :global(.dot-red)    { background: var(--red); }
  :global(.dot-grey)   { background: var(--border-bright); }
  :global(.station-name) {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 500;
  }
  :global(.station-arrivals) {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  :global(.station-delayed) {
    font-size: 0.75rem;
    color: var(--yellow);
    font-family: var(--font-mono);
    font-weight: 500;
    white-space: nowrap;
  }
  :global(.station-arrow) {
    color: var(--text-muted);
    font-size: 1rem;
  }

  /* Insights */
  .insights-section {
    margin-bottom: 2.5rem;
  }

  .insights-grid {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  }

  :global(.insight-card) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.12s, box-shadow 0.12s;
    background: var(--bg-card);
  }
  :global(.insight-ok)   { border-color: var(--green-border);  background: var(--green-bg); }
  :global(.insight-warn) { border-color: var(--yellow-border); background: var(--yellow-bg); }
  :global(.insight-bad)  { border-color: var(--red-border);    background: var(--red-bg); }
  :global(.insight-info) { border-color: var(--accent-border); background: var(--accent-bg); }

  :global(.insight-icon-wrap) {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  :global(.insight-ok   .insight-icon-wrap) { background: rgba(5,150,105,0.14);  color: var(--green); }
  :global(.insight-warn .insight-icon-wrap) { background: rgba(180,83,9,0.12);   color: var(--yellow); }
  :global(.insight-bad  .insight-icon-wrap) { background: rgba(220,38,38,0.1);   color: var(--red); }
  :global(.insight-info .insight-icon-wrap) { background: rgba(13,148,136,0.12); color: var(--accent); }

  :global(.insight-body) { flex: 1; min-width: 0; }
  :global(.insight-label) {
    display: block;
    font-size: 0.63rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }
  :global(.insight-ok   .insight-label) { color: var(--green); }
  :global(.insight-warn .insight-label) { color: var(--yellow); }
  :global(.insight-bad  .insight-label) { color: var(--red); }
  :global(.insight-info .insight-label) { color: var(--accent); }

  :global(.insight-text) {
    font-size: 0.855rem; line-height: 1.5; color: var(--text);
  }

  /* Skeleton */
  .skeleton-row {
    height: 52px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .no-data {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .load-sentinel {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .load-sentinel::after {
    content: '';
    width: 18px;
    height: 18px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Zones section */
  .zones-section { margin-bottom: 2.5rem; }
  .zones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.65rem;
    margin-top: 0.75rem;
  }
  .zone-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 0.9rem;
    cursor: default;
    transition: box-shadow 0.15s;
  }
  .zone-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .zone-card-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.35rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .zone-bar-wrap {
    height: 5px;
    background: var(--border);
    border-radius: 3px;
    margin-bottom: 0.4rem;
    overflow: hidden;
  }
  .zone-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s ease;
  }
  .zone-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--text-sub);
  }
  .zone-stat-delay { color: var(--text); font-weight: 600; }
  .zone-stat-pct.high { color: var(--red); }
  .zone-stat-pct.mid  { color: var(--orange, #f59e0b); }
  .ccaa-map-container {
    width: 100%;
    height: 380px;
    border-radius: 10px;
    border: 1px solid var(--border);
    overflow: hidden;
    margin-top: 0.75rem;
    background: var(--bg-card);
  }
  .ccaa-map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    margin: 0.55rem 0 0.6rem;
    font-size: 0.73rem;
    color: var(--text-sub);
  }
  .legend-item { display: flex; align-items: center; gap: 0.35rem; }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Train type section */
  .train-type-section {
    margin-bottom: 2.5rem;
  }
  .train-type-narrative {
    font-size: 0.82rem;
    color: var(--text-muted);
    padding: 0.65rem 0.75rem 0.25rem;
    line-height: 1.5;
  }
  .info-btn {
    display: flex; align-items: center; justify-content: center;
    width: 26px; height: 26px;
    border: 1px solid var(--border);
    border-radius: 99px;
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .info-btn:hover {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-bg);
  }

  /* Train type info modal */
  :global(.train-type-modal-panel) {
    max-width: 720px;
  }
  :global(.train-type-modal-body) {
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
  }
  :global(.tt-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }
  :global(.tt-card) {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  :global(.tt-card--highlight) {
    border-color: var(--accent-border);
    background: var(--accent-bg);
  }
  :global(.tt-header) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.15rem;
  }
  :global(.tt-badge) {
    font-size: 0.65rem;
    font-weight: 700;
    font-family: var(--font-mono);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.tt-ave)   { background: #dbeafe; color: #1d4ed8; }
  :global(.tt-avlo)  { background: #ede9fe; color: #6d28d9; }
  :global(.tt-alvia) { background: #fce7f3; color: #be185d; }
  :global(.tt-avant) { background: #ffedd5; color: #c2410c; }
  :global(.tt-md)    { background: #dcfce7; color: #15803d; }
  :global(.tt-reg)   { background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; }
  :global(.tt-ld)    { background: #fef9c3; color: #854d0e; }
  :global(.tt-c)     { background: var(--accent-bg); color: var(--accent); }
  :global(.tt-photo) {
    width: 100%;
    margin: 0.4rem 0 0.5rem;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-sub);
    aspect-ratio: 16 / 7;
  }
  :global(.tt-train-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  :global(.tt-name) {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
  }
  :global(.tt-desc) {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }
  :global(.tt-meta) {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: baseline;
    margin-top: 0.1rem;
  }
  :global(.tt-label) {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-sub);
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.tt-value) {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }
  :global(.tt-callout) {
    grid-column: 1 / -1;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--accent-bg);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius);
    padding: 0.875rem 1rem;
    color: var(--accent);
    font-size: 0.78rem;
    line-height: 1.5;
  }
  :global(.tt-callout p) { margin: 0; color: var(--text-muted); }
  :global(.tt-callout strong) { color: var(--text); }
  :global(.tt-callout svg) { flex-shrink: 0; margin-top: 0.1rem; }

  /* History chart */
  .history-section {
    margin-bottom: 2.5rem;
  }

  .range-btns {
    display: flex;
    gap: 0.25rem;
  }
  .range-btn {
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .range-btn:hover { border-color: var(--border-bright); color: var(--text); }
  .range-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .chart-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: 0.75rem 0.5rem 0.5rem;
  }

  /* Station dot */
  :global(.station-dot-lg) {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--green); flex-shrink: 0; transition: background 0.3s;
  }
  :global(.station-dot-lg.has-delays)      { background: var(--yellow); }
  :global(.station-dot-lg.has-high-delays) { background: var(--red); }

  /* Board table (for modal) */
  :global(.board-wrap) { background: var(--bg-card); flex: 1; overflow-y: auto; min-height: 0; }
  :global(.board) { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  :global(.board thead tr) { background: var(--bg); border-bottom: 1px solid var(--border); }
  :global(.board th) {
    padding: 0.65rem 1rem;
    text-align: left; font-size: 0.63rem;
    text-transform: uppercase; letter-spacing: 0.09em;
    font-weight: 600; color: var(--text-muted); white-space: nowrap;
  }
  :global(.board td) {
    padding: 1rem 1rem; border-bottom: 1px solid var(--border); vertical-align: middle;
  }
  :global(.board tbody tr:last-child td) { border-bottom: none; }
  :global(.board tbody tr:hover td) { background: var(--bg-card-hover); }
  :global(.board tbody tr) { cursor: pointer; }
  :global(.board th:nth-child(1)), :global(.board td:nth-child(1)) { min-width: 180px; }
  :global(.board th:nth-child(2)), :global(.board td:nth-child(2)),
  :global(.board th:nth-child(3)), :global(.board td:nth-child(3)) { width: 100px; font-family: var(--font-mono); }
  :global(.board th:nth-child(4)), :global(.board td:nth-child(4)) { width: 80px; }
  :global(.board th:nth-child(5)), :global(.board td:nth-child(5)) { width: 130px; }

  /* Time / delay / badge */
  :global(.time-cell) { font-family: var(--font-mono); font-size: 0.9rem; letter-spacing: 0.02em; }
  :global(.time-on-time) { color: var(--text); }
  :global(.time-leve)    { color: var(--yellow); font-weight: 500; }
  :global(.time-alto)    { color: var(--orange); font-weight: 600; }
  :global(.time-cancel)  { color: var(--text-sub); text-decoration: line-through; }

  :global(.delay-cell) { font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-sub); }
  :global(.delay-leve) { color: var(--yellow); font-weight: 500; }
  :global(.delay-alto) { color: var(--orange); font-weight: 600; }

  :global(.badge) {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.68rem; font-weight: 600;
    padding: 0.2rem 0.55rem; border-radius: 4px;
    letter-spacing: 0.04em; text-transform: uppercase;
    font-family: var(--font-mono); white-space: nowrap;
  }
  :global(.badge-en_hora)      { background: var(--green-bg);  color: var(--green);  border: 1px solid var(--green-border); }
  :global(.badge-retraso_leve) { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow-border); }
  :global(.badge-retraso_alto) { background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange-border); }
  :global(.badge-cancelado)    { background: var(--red-bg);    color: var(--red);    border: 1px solid var(--red-border); }

  :global(.origin-main) { font-weight: 500; font-size: 0.875rem; }
  :global(.origin-dest) { font-size: 0.72rem; color: var(--text-sub); margin-top: 0.1rem; }
  :global(.origin-from) { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.15rem; }
  :global(.route-sep) { color: var(--text-sub); margin-right: 0.2em; }
  :global(.route-tag) {
    display: inline-block; font-size: 0.63rem; font-family: var(--font-mono); font-weight: 700;
    background: var(--accent-bg); color: var(--accent);
    padding: 0.1rem 0.35rem; border-radius: 3px; margin-right: 0.35rem; vertical-align: middle;
  }
  :global(.type-tag) {
    display: inline-block; font-size: 0.6rem; font-family: var(--font-mono); font-weight: 600;
    background: var(--bg); color: var(--text-sub); border: 1px solid var(--border);
    padding: 0.1rem 0.3rem; border-radius: 3px; margin-right: 0.3rem; vertical-align: middle;
  }
  :global(.cancelled-row td) { opacity: 0.55; }
  :global(#modal-arrivals-body tr) { cursor: pointer; }
  :global(.station-name-cell) {
    font-size: 0.78rem; color: var(--text-muted); white-space: nowrap;
  }

  /* Chips (modal header) */
  :global(.chip) {
    font-size: 0.7rem; font-weight: 600; font-family: var(--font-mono);
    padding: 0.2rem 0.55rem; border-radius: 99px; white-space: nowrap;
  }
  :global(.chip-green)  { background: var(--green-bg);  color: var(--green); }
  :global(.chip-yellow) { background: var(--yellow-bg); color: var(--yellow); }
  :global(.chip-red)    { background: var(--red-bg);    color: var(--red); }
  :global(.chip-gray)   { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); }

  /* Empty state & skeleton (modal) */
  :global(.empty-state) {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.75rem; padding: 3rem 1rem;
    color: var(--text-muted); font-size: 0.875rem; text-align: center;
  }
  :global(.skeleton-modal td) { padding: 0; border-bottom: 1px solid var(--border); }
  :global(.skeleton-cell) {
    height: 52px;
    background: linear-gradient(90deg, var(--bg) 25%, var(--border) 50%, var(--bg) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* Station card as button */
  :global(.station-card) { text-align: left; width: 100%; }

  /* Drillable insight cards */
  :global(.insight-drillable) { cursor: pointer; }
  :global(.insight-drillable:hover) {
    transform: translateY(-1px);
    box-shadow: var(--shadow);
  }
  :global(.insight-cta) {
    width: 28px; height: 28px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--text-sub);
    transition: color 0.12s, background 0.12s;
  }
  :global(.insight-drillable:hover .insight-cta) {
    color: var(--accent);
    background: rgba(13,148,136,0.1);
  }

  @media (max-width: 640px) {
    :global(.board th:nth-child(4)), :global(.board td:nth-child(4)) { display: none; }
    :global(.board th), :global(.board td) { padding: 0.75rem 0.65rem; }
  }

  /* ── Section switcher ────────────────────────────────────────────────────── */
  .section-switcher {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .section-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow-sm);
  }
  .section-btn:hover { border-color: var(--border-bright); color: var(--text); }
  .section-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    box-shadow: 0 2px 10px rgba(13, 148, 136, 0.28);
  }

  /* ── Search hero ─────────────────────────────────────────────────────────── */
  .search-hero {
    text-align: center;
    padding: 2.5rem 1rem 1.75rem;
  }
  .search-hero-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .search-hero-sub {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .search-hero .search-wrap {
    max-width: 520px;
    margin: 0 auto;
  }
  .search-icon--hero {
    left: 1.1rem;
  }
  .search-input--hero {
    padding: 1rem 1.25rem 1rem 3.25rem;
    font-size: 1.05rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    border-color: var(--border-bright);
  }
  .search-input--hero:focus {
    box-shadow: 0 0 0 4px var(--accent-bg), var(--shadow);
  }

  /* ── Map section ─────────────────────────────────────────────────────────── */
  .map-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .map-mode-group {
    display: flex;
    gap: 0.25rem;
  }

  .map-mode-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .map-mode-btn:hover { border-color: var(--border-bright); color: var(--text); }
  .map-mode-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .map-legend {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .map-legend-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .map-legend-green  { background: var(--green); }
  .map-legend-yellow { background: var(--yellow); }
  .map-legend-red    { background: var(--red); }

  .map-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    position: relative;
  }

  #map-container {
    height: clamp(420px, calc(100vh - 340px), 700px);
    width: 100%;
  }

  .map-message {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.88);
    color: var(--text-muted);
    font-size: 0.875rem;
    padding: 2rem;
    text-align: center;
    z-index: 500;
  }
</style>

<style is:global>
  /* ── Modals — must be global because they live in sub-components ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0,0,0,0.48);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    width: 100%;
    max-width: 840px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .modal-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .modal-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex: 1;
    min-width: 0;
  }
  .modal-title-wrap h2 { font-size: 1.05rem; font-weight: 700; letter-spacing: -0.02em; }
  .modal-header-right { display: flex; align-items: flex-start; gap: 0.75rem; flex-shrink: 0; }
  .modal-back,
  .modal-close {
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text-muted);
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .modal-back { margin-right: 0.25rem; }
  .modal-back:hover,
  .modal-close:hover { background: var(--bg-card-hover); color: var(--text); border-color: var(--border-bright); }
  .modal-body { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }
  .modal-footer {
    padding: 0.65rem 1.5rem;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--text-sub);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .modal-page-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .modal-page-link:hover { text-decoration: underline; }
  .station-meta { font-size: 0.8rem; color: var(--text-sub); margin-top: 0.15rem; }
  .summary-chips { display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: flex-end; }

  /* Train preview */
  .modal-train-preview {
    margin: 0.85rem 0.25rem 0;
    border-top: 1px solid var(--border);
    padding: 0.85rem 0;
    display: flex;
    gap: 0.65rem;
  }
  .modal-train-preview-img-wrap {
    width: 112px; height: 72px; flex-shrink: 0;
    border-radius: 7px; overflow: hidden;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
  }
  .modal-train-preview-image { width: 100%; height: 100%; object-fit: cover; }
  .modal-train-preview-copy { min-width: 0; display: flex; flex-direction: column; gap: 0.35rem; }
  .modal-train-preview-helper { font-size: 0.68rem; color: var(--text-sub); }
  .modal-train-preview-type {
    font-size: 0.78rem; line-height: 1.2; letter-spacing: 0.03em;
    text-transform: uppercase; font-weight: 700; color: var(--text);
  }
  .modal-train-preview-name { font-size: 0.72rem; color: var(--text); font-family: var(--font-mono); }
  .modal-train-preview-note { font-size: 0.7rem; line-height: 1.35; color: var(--text-muted); }
  .modal-train-preview-license { font-size: 0.62rem; color: var(--text-muted); margin-top: 0.15rem; }

  /* Train viewer */
  .train-viewer-modal {
    position: fixed; inset: 0;
    background: rgba(10, 15, 20, 0.78);
    display: flex; align-items: center; justify-content: center;
    z-index: 1200; padding: 1rem;
  }
  .train-viewer-panel {
    width: min(920px, 100%); max-height: 92vh; overflow: auto;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); box-shadow: var(--shadow);
    padding: 0.9rem; position: relative;
  }
  .train-viewer-close {
    position: absolute; top: 0.55rem; right: 0.55rem;
    width: 32px; height: 32px;
    border: 1px solid var(--border); border-radius: 999px;
    background: var(--bg-card); color: var(--text-muted);
    font-size: 1.1rem; line-height: 1;
  }
  .train-viewer-close:hover { color: var(--text); border-color: var(--border-bright); }
  .train-viewer-image {
    width: 100%; max-height: 38vh; object-fit: contain;
    border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
  }
  .train-viewer-info { margin-top: 0.75rem; }
  .train-viewer-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; }
  .train-viewer-train-name { font-size: 0.78rem; font-family: var(--font-mono); color: var(--text-muted); margin-top: 0.2rem; }
  .train-viewer-route {
    display: flex; align-items: center; gap: 0.5rem;
    margin-top: 0.75rem; padding: 0.6rem 0.85rem;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius-sm); font-size: 0.82rem;
    color: var(--text);
  }
  .train-viewer-station { font-weight: 500; }
  .train-viewer-station--muted { color: var(--text-muted); font-weight: 400; }
  .train-viewer-station--current { font-weight: 700; color: var(--accent); }
  .train-viewer-arrow { color: var(--text-muted); flex-shrink: 0; }
  .train-viewer-times {
    display: flex; gap: 0; margin-top: 0.6rem;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .train-viewer-time-block {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    padding: 0.5rem 0.4rem; border-right: 1px solid var(--border);
    background: var(--bg);
  }
  .train-viewer-time-block:last-child { border-right: none; }
  .train-viewer-time-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.25rem; }
  .train-viewer-time-val { font-size: 0.9rem; font-weight: 600; font-family: var(--font-mono); color: var(--text); }
  .train-viewer-note { font-size: 0.74rem; color: var(--text-muted); margin-top: 0.65rem; line-height: 1.35; }

  @media (max-width: 640px) {
    .modal-backdrop { padding: 0; align-items: flex-end; }
    .modal-panel { max-height: 92vh; border-radius: var(--radius) var(--radius) 0 0; }
    .modal-header { flex-direction: column; gap: 0.75rem; }
    .modal-header-right { align-self: flex-end; }
    .summary-chips { justify-content: flex-start; }
    .modal-train-preview { margin-top: 0.65rem; gap: 0.55rem; padding-top: 0.7rem; }
    .modal-train-preview-img-wrap { width: 95px; height: 62px; }
  }
</style>

<script>
  import { state } from "../lib/store";
  import { setText, setValueWithUnit, timeAgo } from "../lib/utils";
  import { renderHistory, renderTrainTypes } from "../lib/chart";
  import { openModal, closeModal, closeTrainViewer, openTrainViewer } from "../lib/stationModal";
  import { renderInsights, openInsightDrilldown, closeInsightModal } from "../lib/insightModal";
  import { closeTrainTypeDetail, invalidateTypeDetailCache } from "../lib/trainTypeDetailModal";
  import { filterAndRender, showNoData } from "../lib/stations";
  import { initMap, loadGeoIfNeeded, renderMapMarkers } from "../lib/map";
  import { renderCcaaChoropleth, destroyCcaaMap } from "../lib/ccaaMap";

  const SERVICES = [
    { name: "ave-larga-distancia", label: "AVE · Larga y Media Distancia", slug: "ave-larga-distancia" },
    { name: "cercanias",           label: "Cercanías",                     slug: "cercanias" },
  ];

  const REFRESH_INTERVAL = 60_000;

  // ── Tabs ───────────────────────────────────────────────────────────────────

  function initTabs() {
    const hash = location.hash.replace("#", "");
    if (SERVICES.some(s => s.name === hash)) state.activeSvc = hash;

    document.querySelectorAll<HTMLButtonElement>(".tab").forEach(btn => {
      if (btn.dataset.svc === state.activeSvc) btn.classList.add("active");
      btn.addEventListener("click", () => {
        state.activeSvc = btn.dataset.svc!;
        location.hash = state.activeSvc;
        document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
        btn.classList.add("active");
        state.allStations = [];
        resetStats();
        invalidateTypeDetailCache();
        const searchInput = document.getElementById("station-search") as HTMLInputElement | null;
        if (searchInput) searchInput.value = "";
        loadDashboard();
      });
    });
  }

  function resetStats() {
    ["v-total","v-delayed","v-avg","v-max","v-trips"].forEach(id => setText(id, "—"));
    setText("sub-stations", "— estaciones");
    setText("sub-pct", "—% del total");
    setText("sub-avg", "minutos");
    setText("sub-max", "minutos");
    setText("sub-trips", "— estaciones activas");
    document.getElementById("sc-max")?.classList.remove("stat-card--clickable");
    setText("last-updated", "Cargando datos…");
    state.scrollObserver?.disconnect();
    state.scrollObserver = null;
    state.filteredStations = [];
    state.displayedCount = 0;
    const list = document.getElementById("stations-list")!;
    list.innerHTML = `<div class="skeleton-row"></div>`.repeat(5);
    document.getElementById("no-data")!.style.display = "none";
    document.getElementById("station-count")!.textContent = "—";
    document.getElementById("history-section")!.style.display = "none";
    document.getElementById("insights-section")!.style.display = "none";
    document.getElementById("train-type-section")!.style.display = "none";
    document.getElementById("zones-section")!.style.display = "none";
    document.getElementById("zones-nucleo-header")!.style.display = "none";
    (document.getElementById("zones-ccaa-grid") as HTMLElement).innerHTML = "";
    (document.getElementById("zones-nucleo-grid") as HTMLElement).innerHTML = "";
    destroyCcaaMap();
    state.trainTypeChart?.dispose();
    state.trainTypeChart = null;
    state.historyRecords = [];
    state.chart?.dispose();
    state.chart = null;
  }

  // ── Zones ──────────────────────────────────────────────────────────────────

  async function loadZones() {
    try {
      const res = await fetch(`/data/${state.activeSvc}/zones.json?t=${Date.now()}`);
      if (!res.ok) return;
      const { ccaa = [], nucleos = [] } = await res.json();
      renderZones(ccaa, nucleos);
    } catch {
      // zones not yet available
    }
  }

  function renderZones(ccaa: any[], nucleos: any[]) {
    if (!ccaa.length && !nucleos.length) return;

    const zoneCard = (z: any) => {
      const delayedPct = z.total > 0 ? z.delayed / z.total : 0;
      const barPct = Math.min(delayedPct * 100, 100).toFixed(1);
      const pctClass = delayedPct >= 0.3 ? "high" : delayedPct >= 0.15 ? "mid" : "";
      const avgDelay = z.avg_delay_min > 0
        ? `<span class="zone-stat-delay">${z.avg_delay_min.toFixed(1)}m</span>`
        : "";
      return `<div class="zone-card">
        <div class="zone-card-name" title="${z.name}">${z.name}</div>
        <div class="zone-bar-wrap"><div class="zone-bar" style="width:${barPct}%"></div></div>
        <div class="zone-stats">
          <span class="zone-stat-pct ${pctClass}">${(delayedPct * 100).toFixed(0)}% retrasos</span>
          ${avgDelay}
        </div>
        <div class="zone-stats" style="font-size:0.72rem;color:var(--muted);margin-top:0.15rem">
          ${z.total} trenes · ${z.stations_count} est.
        </div>
      </div>`;
    };

    const ccaaGrid = document.getElementById("zones-ccaa-grid")!;
    ccaaGrid.innerHTML = ccaa.map(zoneCard).join("");

    const nucleoGrid = document.getElementById("zones-nucleo-grid")!;
    const nucleoHeader = document.getElementById("zones-nucleo-header")!;
    if (nucleos.length) {
      nucleoGrid.innerHTML = nucleos.map(zoneCard).join("");
      nucleoHeader.style.display = "";
    }

    document.getElementById("zones-section")!.style.display = "";

    // Render choropleth after section is visible (Leaflet needs layout)
    requestAnimationFrame(() => renderCcaaChoropleth(ccaa));
  }

  // ── Data ───────────────────────────────────────────────────────────────────

  async function loadDashboard() {
    const url = `/data/${state.activeSvc}/stats.json?t=${Date.now()}`;
    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      renderStats(data.stats, data.generated_at);
      state.allStations = data.stations || [];
      filterAndRender();
      if (document.getElementById("section-map")!.style.display !== "none") {
        loadGeoIfNeeded().then(() => renderMapMarkers());
      }
    } catch (err) {
      console.warn(`Error cargando ${state.activeSvc}:`, err);
      showNoData();
    }
    loadHistory();
    loadInsights();
    loadZones();
  }

  async function loadHistory() {
    try {
      const res = await fetch(`/data/${state.activeSvc}/history.json?t=${Date.now()}`);
      if (!res.ok) return;
      const { records = [] } = await res.json();
      state.historyRecords = records;
      renderHistory();
    } catch {
      // history not yet available — hide quietly
    }
  }

  async function loadInsights() {
    try {
      const res = await fetch(`/data/${state.activeSvc}/insights.json?t=${Date.now()}`);
      if (!res.ok) return;
      const { insights = [] } = await res.json();
      renderInsights(insights);
    } catch {
      // not yet available
    }
  }

  function renderStats(s: any, generatedAt: string) {
    setValueWithUnit("v-total", s.total_trains?.toLocaleString("es") ?? null, " paradas");
    setText("sub-stations", `${s.stations_count ?? "—"} estaciones`);
    setValueWithUnit("v-delayed", s.delayed?.toLocaleString("es") ?? null, " paradas");

    const pct = s.total_trains
      ? Math.round((s.delayed / s.total_trains) * 100)
      : null;
    setText("sub-pct", pct !== null ? `${pct}% del total` : "—");

    setValueWithUnit("v-avg", s.avg_delay_min != null ? s.avg_delay_min : null, " min");
    setText("sub-avg", s.delayed > 0 ? `sobre ${s.delayed} tren${s.delayed !== 1 ? "es" : ""} retrasado${s.delayed !== 1 ? "s" : ""}` : "");

    setValueWithUnit("v-max", s.max_delay_min != null ? s.max_delay_min : null, " min");
    const maxSt = s.max_delay_station;
    if (maxSt?.station_name) {
      const label = maxSt.train_name ? `${maxSt.train_name} · ${maxSt.station_name}` : maxSt.station_name;
      setText("sub-max", label);
      const scMax = document.getElementById("sc-max");
      if (scMax) {
        scMax.classList.add("stat-card--clickable");
        scMax.dataset.stationId = maxSt.stop_id;
        scMax.dataset.stationName = maxSt.station_name;
      }
    } else {
      setText("sub-max", "minutos");
    }

    setValueWithUnit("v-trips", s.unique_trips?.toLocaleString("es") ?? null, " trenes");
    setText("sub-trips", s.stations_count ? `de ${s.stations_count} estaciones` : "—");

    setText("last-updated", `Actualizado ${timeAgo(generatedAt)}`);
    renderTrainTypes(s.by_train_type ?? {});
  }

  function startCountdown() {
    state.nextRefreshAt = Date.now() + REFRESH_INTERVAL;
    const bar = document.getElementById("refresh-bar") as HTMLElement;
    if (state.countdownTimer) clearInterval(state.countdownTimer);
    state.countdownTimer = setInterval(() => {
      const remaining = Math.max(0, state.nextRefreshAt - Date.now());
      bar.style.transform = `scaleX(${remaining / REFRESH_INTERVAL})`;
    }, 500);
  }

  // ── Section switcher ───────────────────────────────────────────────────────

  function switchSection(section: "analytics" | "stations" | "map") {
    document.querySelectorAll<HTMLButtonElement>(".section-btn").forEach(btn => {
      const isActive = btn.dataset.section === section;
      btn.classList.toggle("active", isActive);
      btn.setAttribute("aria-selected", String(isActive));
    });
    document.getElementById("section-analytics")!.style.display = section === "analytics" ? "" : "none";
    document.getElementById("section-stations")!.style.display  = section === "stations"  ? "" : "none";
    document.getElementById("section-map")!.style.display       = section === "map"       ? "" : "none";
    if (section === "stations") {
      (document.getElementById("station-search") as HTMLInputElement)?.focus();
    }
    if (section === "map") {
      initMap().then(() => {
        loadGeoIfNeeded().then(() => renderMapMarkers());
      });
    }
  }

  // ── Event listeners ────────────────────────────────────────────────────────

  // Search
  document.getElementById("station-search")?.addEventListener("input", filterAndRender);

  // Range buttons
  document.querySelectorAll<HTMLButtonElement>(".range-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      state.activeDays = Number(btn.dataset.days);
      document.querySelectorAll(".range-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      renderHistory();
    });
  });

  // Insight grid clicks
  document.getElementById("insights-grid")!.addEventListener("click", (e) => {
    const card = (e.target as HTMLElement).closest<HTMLElement>(".insight-drillable");
    if (!card) return;
    const insightId = card.dataset.insightId;
    const meta = JSON.parse(decodeURIComponent(card.dataset.meta ?? "{}"));
    if (insightId === "B" || insightId === "C") {
      openModal(meta.station_id, meta.station_name);
    } else if (insightId === "A") {
      openInsightDrilldown(meta);
    }
  });

  // Insight modal
  document.getElementById("insight-modal-close")!.addEventListener("click", closeInsightModal);
  document.getElementById("insight-modal")!.addEventListener("click", (e) => {
    if (e.target === document.getElementById("insight-modal")) closeInsightModal();
  });
  document.getElementById("insight-modal")!.addEventListener("click", (e) => {
    const card = (e.target as HTMLElement).closest<HTMLElement>(".station-card");
    if (!card?.dataset.id) return;
    openModal(card.dataset.id, card.dataset.name ?? "", true);
  });

  // Station list clicks
  document.getElementById("stations-list")!.addEventListener("click", (e) => {
    const card = (e.target as HTMLElement).closest<HTMLElement>(".station-card");
    if (!card || !card.dataset.id) return;
    openModal(card.dataset.id, card.dataset.name ?? "");
  });

  // Station modal
  document.getElementById("modal-close")!.addEventListener("click", closeModal);
  document.getElementById("modal-back")!.addEventListener("click", closeModal);
  document.getElementById("station-modal")!.addEventListener("click", (e) => {
    if (e.target === document.getElementById("station-modal")) closeModal();
  });

  // Train viewer
  document.querySelector(".modal-train-preview-img-wrap")?.addEventListener("click", openTrainViewer);
  document.getElementById("train-viewer-close")?.addEventListener("click", closeTrainViewer);
  document.getElementById("train-viewer-modal")!.addEventListener("click", (e) => {
    if (e.target === document.getElementById("train-viewer-modal")) closeTrainViewer();
  });

  // Train type drilldown modal
  document.getElementById("tt-detail-close")!.addEventListener("click", closeTrainTypeDetail);
  document.getElementById("tt-detail-modal")!.addEventListener("click", (e) => {
    if (e.target === document.getElementById("tt-detail-modal")) closeTrainTypeDetail();
  });

  // Escape key (topmost modal first)
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    const tvModal = document.getElementById("train-viewer-modal") as HTMLElement;
    const stModal = document.getElementById("station-modal") as HTMLElement;
    const inModal = document.getElementById("insight-modal") as HTMLElement;
    const ttInfoModal = document.getElementById("train-type-modal") as HTMLElement;
    const ttDetailModal = document.getElementById("tt-detail-modal") as HTMLElement;
    if (tvModal.style.display !== "none") closeTrainViewer();
    else if (stModal.style.display !== "none") closeModal();
    else if (inModal.style.display !== "none") closeInsightModal();
    else if (ttDetailModal.style.display !== "none") closeTrainTypeDetail();
    else if (ttInfoModal.style.display !== "none") { ttInfoModal.style.display = "none"; document.body.style.overflow = ""; }
  });

  // Section switcher buttons
  document.querySelectorAll<HTMLButtonElement>(".section-btn").forEach(btn => {
    btn.addEventListener("click", () => switchSection(btn.dataset.section as "analytics" | "stations" | "map"));
  });

  // Map mode buttons
  document.querySelectorAll<HTMLButtonElement>(".map-mode-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      state.mapMode = btn.dataset.mode as "scatter" | "heat";
      document.querySelectorAll(".map-mode-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      renderMapMarkers();
    });
  });

  // Train type info modal
  const ttModal = document.getElementById("train-type-modal") as HTMLElement;
  document.getElementById("train-type-info-btn")?.addEventListener("click", () => {
    ttModal.style.display = "flex";
    document.body.style.overflow = "hidden";
  });
  const closeTtModal = () => {
    ttModal.style.display = "none";
    document.body.style.overflow = "";
  };
  document.getElementById("train-type-modal-close")?.addEventListener("click", closeTtModal);
  ttModal.addEventListener("click", (e) => { if (e.target === ttModal) closeTtModal(); });

  // Max-delay stat card click
  document.getElementById("sc-max")?.addEventListener("click", () => {
    const el = document.getElementById("sc-max") as HTMLElement;
    if (!el.classList.contains("stat-card--clickable")) return;
    const id = el.dataset.stationId;
    const name = el.dataset.stationName ?? "";
    if (id) openModal(id, name);
  });

  // ── Init ───────────────────────────────────────────────────────────────────
  initTabs();
  loadDashboard();
  startCountdown();
  state.refreshTimer = setInterval(() => {
    loadDashboard();
    startCountdown();
  }, REFRESH_INTERVAL);
</script>

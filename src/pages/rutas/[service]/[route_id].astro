---
import { readFileSync } from "fs";
import { resolve } from "path";
import Layout from "../../../layouts/Layout.astro";

export function getStaticPaths() {
  const services = ["cercanias", "ave-larga-distancia"];
  const paths: any[] = [];

  for (const service of services) {
    try {
      const raw = readFileSync(resolve(`public/data/${service}/routes_geo.json`), "utf-8");
      const { routes } = JSON.parse(raw);
      for (const route of routes) {
        const slug = route.route_id.replace(/[^a-zA-Z0-9_-]/g, "_");
        paths.push({
          params: { service, route_id: slug },
          props: { route, service },
        });
      }
    } catch {}
  }

  return paths;
}

const { route, service } = Astro.props;
const serviceLabel = service === "cercanias" ? "Cercanías" : "AVE · Larga y Media Distancia";
const serviceColor = service === "cercanias" ? "#0d9488" : "#2563eb";

// Derive display name
function getDisplayName(r: any): string {
  if (r.route_long_name && r.route_long_name.trim() !== r.route_short_name.trim()) {
    return r.route_long_name.trim();
  }
  if (r.stops?.length >= 2) {
    return `${r.stops[0].name} → ${r.stops[r.stops.length - 1].name}`;
  }
  return r.route_short_name;
}

const displayName = getDisplayName(route);
const badgeColor = route.route_color && !["F2F5F5", "FFFFFF"].includes(route.route_color)
  ? `#${route.route_color}`
  : serviceColor;

const stats = route.stats ?? {};
const chronic = route.chronic_stats ?? {};
const hasCurrentTraffic = (stats.total ?? 0) > 0;
const hasChronicData = (chronic.chronic_n_snapshots ?? 0) > 0;

const pct = Math.round((stats.delayed_pct ?? 0) * 100);
const chronicPct = Math.round((chronic.chronic_delayed_pct ?? 0) * 100);
---

<Layout
  title={`${route.route_short_name} — ${displayName}`}
  description={`Retrasos históricos y trayecto de la ruta ${route.route_short_name}: ${displayName}. Datos de Renfe en enhora.info.`}
  ogUrl={`https://enhora.info/rutas/${service}/${Astro.params.route_id}`}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Navegación">
    <a href="/">Inicio</a>
    <span>›</span>
    <a href={`/rutas#${service}`}>Rutas</a>
    <span>›</span>
    <span>{route.route_short_name}</span>
  </nav>

  <!-- Header -->
  <div class="route-header">
    <div class="route-title-row">
      <span class="route-badge" style={`background:${badgeColor}`}>{route.route_short_name}</span>
      <h1 class="route-name">{displayName}</h1>
    </div>
    <span class="service-tag" style={`border-color:${serviceColor};color:${serviceColor}`}>{serviceLabel}</span>
  </div>

  <!-- Stats grid -->
  <div class="stats-grid">
    <!-- Current snapshot -->
    <div class="stat-card">
      <h2 class="card-title">Ahora</h2>
      {hasCurrentTraffic ? (
        <div class="stat-row">
          <div class="stat-item">
            <span class="stat-value" style={`color:${pct >= 30 ? "#dc2626" : pct >= 10 ? "#b45309" : "#059669"}`}>{pct}%</span>
            <span class="stat-label">con retraso</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{stats.total}</span>
            <span class="stat-label">trenes</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{stats.avg_delay_min > 0 ? `${stats.avg_delay_min.toFixed(1)} min` : "—"}</span>
            <span class="stat-label">media</span>
          </div>
          <div class="stat-item">
            <span class="stat-value" class:list={[stats.max_delay_min > 10 && "stat-red"]}>{stats.max_delay_min > 0 ? `${Math.round(stats.max_delay_min)} min` : "—"}</span>
            <span class="stat-label">máximo</span>
          </div>
        </div>
      ) : (
        <p class="no-data">Sin tráfico en la ventana actual</p>
      )}
    </div>

    <!-- Chronic / historical -->
    <div class="stat-card">
      <h2 class="card-title">Histórico</h2>
      {hasChronicData ? (
        <div class="stat-row">
          <div class="stat-item">
            <span class="stat-value" style={`color:${chronicPct >= 30 ? "#dc2626" : chronicPct >= 10 ? "#b45309" : "#059669"}`}>{chronicPct}%</span>
            <span class="stat-label">con retraso</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{chronic.chronic_avg_delay_min > 0 ? `${chronic.chronic_avg_delay_min.toFixed(1)} min` : "—"}</span>
            <span class="stat-label">media histórica</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{chronic.chronic_n_snapshots}</span>
            <span class="stat-label">snapshots</span>
          </div>
        </div>
      ) : (
        <p class="no-data">Sin datos históricos aún</p>
      )}
    </div>
  </div>

  <!-- Map + stops -->
  <div class="detail-layout">
    <!-- Map -->
    <div class="map-wrap">
      <div
        id="route-map"
        class="route-map"
        data-route={JSON.stringify({ shape: route.shape, stops: route.stops, stats: route.stats })}
      ></div>
    </div>

    <!-- Stops rail -->
    <div class="stops-panel">
      <h2 class="panel-title">Paradas ({route.stops?.length ?? 0})</h2>
      {route.stops?.length > 0 ? (
        <ol class="stops-rail">
          {route.stops.map((s: any, i: number) => {
            const isTerminal = i === 0 || i === route.stops.length - 1;
            return (
              <li class:list={["stop-item", isTerminal && "stop-terminal"]}>
                <span class="stop-name">{s.name}</span>
              </li>
            );
          })}
        </ol>
      ) : (
        <p class="no-data">Sin paradas disponibles</p>
      )}
    </div>
  </div>
</Layout>

<script>
  import "leaflet/dist/leaflet.css";
  import L from "leaflet";

  const container = document.getElementById("route-map") as HTMLElement;
  if (container) {
    const routeData = JSON.parse(container.dataset.route!);
    const shape = routeData.shape as [number, number][];
    const stops = routeData.stops as { lat: number; lon: number; name: string }[] || [];

    const map = L.map(container, { center: [40.2, -3.5], zoom: 6 });
    L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: "abcd",
      maxZoom: 19,
    }).addTo(map);

    if (shape && shape.length >= 2) {
      const pct   = routeData.stats?.delayed_pct ?? 0;
      const total = routeData.stats?.total ?? 0;
      const color = total === 0 ? "#c8cfd8"
        : pct >= 0.5 ? "#dc2626"
        : pct >= 0.3 ? "#c2410c"
        : pct >= 0.1 ? "#b45309"
        : pct > 0    ? "#65a30d"
        : "#059669";
      const line = L.polyline(shape, { color, weight: 4, opacity: 0.85 }).addTo(map);
      map.fitBounds(line.getBounds(), { padding: [32, 32] });
    } else if (stops.length > 0) {
      map.fitBounds(L.latLngBounds(stops.map(s => [s.lat, s.lon])), { padding: [32, 32] });
    }

    for (let i = 0; i < stops.length; i++) {
      const s = stops[i];
      const isTerminal = i === 0 || i === stops.length - 1;
      L.circleMarker([s.lat, s.lon], {
        radius:      isTerminal ? 7 : 4,
        color:       "#fff",
        weight:      isTerminal ? 2 : 1.5,
        fillColor:   isTerminal ? "#0d9488" : "#6b7280",
        fillOpacity: 1,
      }).bindTooltip(s.name, { sticky: true }).addTo(map);
    }
  }
</script>

<style>
  /* ── Breadcrumb ───────────────────────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .route-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.1rem;
  }
  .route-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .route-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-sm);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .route-name {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .service-tag {
    font-size: 0.72rem;
    border: 1px solid;
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.55rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Stats ───────────────────────────────────────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 600px) { .stats-grid { grid-template-columns: 1fr; } }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.8rem 1rem;
    box-shadow: var(--shadow-sm);
  }
  .card-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-sub);
    margin-bottom: 0.6rem;
  }
  .stat-row {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
  }
  .stat-red { color: var(--red) !important; }
  .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .no-data {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  /* ── Detail layout ───────────────────────────────────────────────────────── */
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 1rem;
    align-items: start;
  }
  @media (max-width: 860px) {
    .detail-layout { grid-template-columns: 1fr; }
  }

  /* ── Map ─────────────────────────────────────────────────────────────────── */
  .map-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .route-map {
    height: 480px;
    min-height: 300px;
  }
  @media (max-width: 860px) { .route-map { height: 320px; } }

  /* ── Stops panel ─────────────────────────────────────────────────────────── */
  .stops-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem 1rem;
    box-shadow: var(--shadow-sm);
    max-height: 520px;
    overflow-y: auto;
  }
  .panel-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-sub);
    margin-bottom: 0.5rem;
  }

  /* Stops rail */
  .stops-rail {
    list-style: none;
    position: relative;
    padding: 0 0 0 1.8rem;
    margin: 0;
  }
  .stops-rail::before {
    content: '';
    position: absolute;
    left: calc(1rem - 1px);
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent) 0%, var(--border-bright) 100%);
  }
  .stop-item {
    position: relative;
    padding: 0.25rem 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.3;
  }
  .stop-item::before {
    content: '';
    position: absolute;
    left: -0.8rem;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border-bright);
  }
  .stop-terminal {
    color: var(--text);
    font-weight: 600;
  }
  .stop-terminal::before {
    width: 10px;
    height: 10px;
    border-color: var(--accent);
    border-width: 2.5px;
  }
  .stop-name { display: block; }
</style>

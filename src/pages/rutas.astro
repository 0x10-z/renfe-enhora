---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Rutas"
  description="Ranking de rutas de Renfe por porcentaje de retraso. Mapa interactivo con trayectos y paradas de Cercanías, AVE y Larga Distancia."
  ogUrl="https://enhora.info/rutas"
>
  <div class="page-header">
    <div>
      <h1>Rutas</h1>
      <p class="subtitle">Selecciona una ruta para ver su trayecto y todas sus paradas</p>
    </div>
    <span id="last-updated" class="muted"></span>
  </div>

  <!-- Service tabs -->
  <div class="tabs" id="service-tabs" role="tablist">
    <button class="tab" data-svc="ave-larga-distancia" role="tab">AVE · Larga y Media Distancia</button>
    <button class="tab" data-svc="cercanias" role="tab">Cercanías</button>
  </div>

  <!-- Legend -->
  <div class="legend-bar">
    <span class="legend-item"><span class="legend-swatch" style="background:#dc2626"></span>≥ 50%</span>
    <span class="legend-item"><span class="legend-swatch" style="background:#c2410c"></span>30–50%</span>
    <span class="legend-item"><span class="legend-swatch" style="background:#b45309"></span>10–30%</span>
    <span class="legend-item"><span class="legend-swatch" style="background:#65a30d"></span>&lt; 10%</span>
    <span class="legend-item"><span class="legend-swatch" style="background:#059669"></span>En hora</span>
    <span class="legend-item"><span class="legend-swatch" style="background:#c8cfd8"></span>Sin tráfico</span>
  </div>

  <!-- Main layout -->
  <div class="routes-layout">

    <!-- Left panel (ranking / detail) -->
    <div class="left-panel">

      <!-- ── VIEW A: Ranking ────────────────────────────────────────── -->
      <div id="view-ranking">
        <div class="panel-head">
          <span class="panel-title">Ranking de rutas</span>
          <span id="routes-count" class="muted small"></span>
        </div>
        <div class="filter-bar">
          <input id="route-search" type="search" placeholder="Buscar línea o estación…" class="filter-input" autocomplete="off" />
          <select id="type-filter" class="filter-select">
            <option value="">Todos los tipos</option>
            <option value="AVE">AVE</option>
            <option value="AVLO">AVLO</option>
            <option value="Alvia">Alvia</option>
            <option value="Avant">Avant</option>
            <option value="Media Distancia">Media Distancia</option>
            <option value="Larga Distancia">Larga Distancia</option>
            <option value="Regional">Regional</option>
            <option value="Cercanías">Cercanías</option>
            <option value="Otros">Otros</option>
          </select>
        </div>
        <ul class="routes-list" id="routes-list">
          <li class="list-placeholder">Cargando rutas…</li>
        </ul>
      </div>

      <!-- ── VIEW B: Route detail ──────────────────────────────────── -->
      <div id="view-detail" class="hidden">
        <button id="back-btn" class="back-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Volver al ranking
        </button>

        <!-- Route header -->
        <div class="detail-header" id="detail-header"></div>

        <!-- Stats strip -->
        <div class="detail-stats" id="detail-stats"></div>

        <!-- Stops rail -->
        <div class="stops-section">
          <p class="stops-label">Paradas del trayecto</p>
          <ul class="stops-rail" id="stops-rail"></ul>
        </div>
      </div>

    </div>

    <!-- Right: map (always full height) -->
    <div class="map-panel">
      <div id="routes-map" class="routes-map"></div>
    </div>

  </div>
</Layout>

<script>
  import {
    initRoutesMap,
    loadRoutesData,
    renderRoutePolylines,
    selectRoute,
    getDisplayName,
    delayColor,
    type RouteGeo,
  } from "../lib/routesMap";

  // ── State ──────────────────────────────────────────────────────────────────
  let currentService = "ave-larga-distancia";
  let allRoutes: RouteGeo[] = [];

  // ── Init ───────────────────────────────────────────────────────────────────
  async function init() {
    await initRoutesMap("routes-map");
    const hash = location.hash.replace("#", "");
    if (hash === "cercanias" || hash === "ave-larga-distancia") currentService = hash;
    activateTab(currentService);
    await loadService(currentService);
  }

  // ── Tabs ───────────────────────────────────────────────────────────────────
  function activateTab(svc: string) {
    document.querySelectorAll<HTMLButtonElement>(".tab").forEach(b => {
      b.classList.toggle("active", b.dataset.svc === svc);
      b.setAttribute("aria-selected", String(b.dataset.svc === svc));
    });
  }

  document.getElementById("service-tabs")!.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-svc]");
    if (!btn || btn.dataset.svc === currentService) return;
    currentService = btn.dataset.svc!;
    activateTab(currentService);
    location.hash = currentService;
    showRankingView();
    await loadService(currentService);
  });

  // ── Load ───────────────────────────────────────────────────────────────────
  async function loadService(svc: string) {
    const listEl = document.getElementById("routes-list")!;
    listEl.innerHTML = `<li class="list-placeholder">Cargando rutas…</li>`;
    try {
      allRoutes = await loadRoutesData(svc);
      updateMeta();
      applyFilters();
    } catch {
      listEl.innerHTML = `<li class="list-error">No hay datos disponibles. Ejecuta el pipeline para generar routes_geo.json.</li>`;
    }
  }

  function updateMeta() {
    const active = allRoutes.filter(r => r.stats.total > 0).length;
    const el = document.getElementById("last-updated");
    if (el) el.textContent = `${allRoutes.length} rutas · ${active} activas ahora`;
  }

  // ── Filters ────────────────────────────────────────────────────────────────
  function applyFilters() {
    const search     = (document.getElementById("route-search") as HTMLInputElement).value.toLowerCase().trim();
    const typeFilter = (document.getElementById("type-filter") as HTMLSelectElement).value;

    const filtered = allRoutes.filter(r => {
      const dn = getDisplayName(r).toLowerCase();
      const matchSearch = !search || r.route_short_name.toLowerCase().includes(search) || dn.includes(search);
      const matchType   = !typeFilter || getRouteType(r) === typeFilter;
      return matchSearch && matchType;
    });

    renderRankingList(filtered);
    renderRoutePolylines(filtered);
    const el = document.getElementById("routes-count");
    if (el) el.textContent = `${filtered.length} ruta${filtered.length !== 1 ? "s" : ""}`;
  }

  document.getElementById("route-search")!.addEventListener("input", applyFilters);
  document.getElementById("type-filter")!.addEventListener("change", applyFilters);

  function getRouteType(r: RouteGeo): string {
    const s = r.route_short_name.toUpperCase();
    if (s.startsWith("AVLO") || s === "AV2")   return "AVLO";
    if (s.startsWith("AVE"))                   return "AVE";
    if (s.startsWith("ALVIA"))                 return "Alvia";
    if (s.startsWith("AVANT"))                 return "Avant";
    if (s.startsWith("MD") || s === "PROXIMDAD") return "Media Distancia";
    if (s.startsWith("LD"))                    return "Larga Distancia";
    if (s.startsWith("REG") || s.startsWith("RG") || s === "REGIONAL" || s === "REG.EXP.") return "Regional";
    if (/^C\d/.test(s) || /^R\d/.test(s))     return "Cercanías";
    return "Otros";
  }

  // ── Ranking list ───────────────────────────────────────────────────────────
  function renderRankingList(routes: RouteGeo[]) {
    const list = document.getElementById("routes-list")!;

    if (routes.length === 0) {
      list.innerHTML = `<li class="list-empty">Sin rutas para los filtros seleccionados</li>`;
      return;
    }

    // Active routes first, then inactive (already sorted by pipeline, but ensure)
    const active   = routes.filter(r => r.stats.total > 0);
    const inactive = routes.filter(r => r.stats.total === 0);
    const ordered  = [...active, ...inactive];

    list.innerHTML = ordered.map((r, idx) => {
      const pct        = Math.round(r.stats.delayed_pct * 100);
      const color      = delayColor(r.stats.delayed_pct, r.stats.total);
      const badgeBg    = getBadgeColor(r);
      const displayName = getDisplayName(r);
      const isActive   = r.stats.total > 0;
      const rank       = idx + 1;

      // Build compact stats string for active routes
      let statsStr = "";
      if (isActive) {
        const parts = [`${r.stats.total} trenes`];
        if (r.stats.avg_delay_min > 0) parts.push(`${r.stats.avg_delay_min.toFixed(1)} min media`);
        if (r.stats.max_delay_min > 0) parts.push(`máx ${Math.round(r.stats.max_delay_min)} min`);
        statsStr = parts.join(" · ");
      }

      const slug = r.route_id.replace(/[^a-zA-Z0-9_-]/g, "_");
      const detailUrl = `/rutas/${currentService}/${slug}`;
      return `<li class="route-card${isActive ? "" : " route-card--inactive"}" data-route-id="${r.route_id}" tabindex="0" role="button" title="${displayName}">
        <div class="rc-top">
          <span class="rc-rank">${rank}</span>
          <span class="rc-badge" style="--badge-bg:${badgeBg}">${r.route_short_name}</span>
          <span class="rc-name">${displayName}</span>
          <span class="rc-pct" style="color:${color}">${isActive ? pct + "%" : ""}</span>
        </div>
        ${isActive ? `
        <div class="rc-bar-wrap">
          <div class="rc-bar" style="width:${pct}%;background:${color}"></div>
        </div>
        <div class="rc-stats">${statsStr} <a class="rc-detail-link" href="${detailUrl}" title="Ver detalle de ruta">↗</a></div>` : ""}
      </li>`;
    }).join("");

    list.querySelectorAll<HTMLElement>(".route-card").forEach(el => {
      el.addEventListener("click", () => selectRoute(el.dataset.routeId!));
      el.addEventListener("keydown", (e) => { if (e.key === "Enter") el.click(); });
    });
  }

  function getBadgeColor(r: RouteGeo): string {
    if (r.route_color && r.route_color !== "F2F5F5" && r.route_color !== "FFFFFF") {
      return `#${r.route_color}`;
    }
    // Fallback by type
    const s = r.route_short_name.toUpperCase();
    if (s.startsWith("AVE"))   return "#c0392b";
    if (s.startsWith("AVLO"))  return "#8e44ad";
    if (s.startsWith("ALVIA")) return "#2980b9";
    if (s.startsWith("AVANT")) return "#16a085";
    if (s.startsWith("MD"))    return "#d35400";
    if (s.startsWith("LD"))    return "#27ae60";
    if (s.startsWith("REG") || s.startsWith("RG")) return "#7f8c8d";
    return "#0d9488";
  }

  // ── Detail view (triggered by map/list click via CustomEvent) ──────────────
  document.addEventListener("route:selected", (e: Event) => {
    const route = (e as CustomEvent<RouteGeo>).detail;
    renderDetailView(route);
    showDetailView();

    // Also highlight item in ranking list (in case it's visible)
    document.querySelectorAll(".route-card").forEach(el => el.classList.remove("selected"));
    document.querySelector(`[data-route-id="${route.route_id}"]`)?.classList.add("selected");
  });

  function renderDetailView(r: RouteGeo) {
    const color     = delayColor(r.stats.delayed_pct, r.stats.total);
    const badgeBg   = getBadgeColor(r);
    const displayName = getDisplayName(r);
    const pct       = Math.round(r.stats.delayed_pct * 100);
    const isActive  = r.stats.total > 0;

    // Header
    const header = document.getElementById("detail-header")!;
    header.innerHTML = `
      <span class="rc-badge rc-badge--lg" style="--badge-bg:${badgeBg}">${r.route_short_name}</span>
      <span class="detail-name">${displayName}</span>
    `;

    // Stats strip
    const stats = document.getElementById("detail-stats")!;
    if (isActive) {
      stats.innerHTML = `
        <div class="ds-item">
          <span class="ds-value" style="color:${color}">${pct}%</span>
          <span class="ds-label">con retraso</span>
        </div>
        <div class="ds-item">
          <span class="ds-value">${r.stats.total}</span>
          <span class="ds-label">trenes</span>
        </div>
        <div class="ds-item">
          <span class="ds-value">${r.stats.avg_delay_min > 0 ? r.stats.avg_delay_min.toFixed(1) + " min" : "—"}</span>
          <span class="ds-label">media</span>
        </div>
        <div class="ds-item">
          <span class="ds-value${r.stats.max_delay_min > 10 ? " ds-red" : ""}">${r.stats.max_delay_min > 0 ? Math.round(r.stats.max_delay_min) + " min" : "—"}</span>
          <span class="ds-label">máximo</span>
        </div>
      `;
    } else {
      stats.innerHTML = `<div class="ds-inactive">Sin tráfico en la ventana actual</div>`;
    }

    // Stops rail
    const rail = document.getElementById("stops-rail")!;
    if (r.stops.length === 0) {
      rail.innerHTML = `<li class="stop-empty">Sin paradas disponibles</li>`;
      return;
    }

    rail.innerHTML = r.stops.map((s, i) => {
      const isFirst = i === 0;
      const isLast  = i === r.stops.length - 1;
      const cls = isFirst || isLast ? " stop-terminal" : "";
      return `<li class="stop-item${cls}">
        <span class="stop-name">${s.name}</span>
      </li>`;
    }).join("");
  }

  // ── View toggle ────────────────────────────────────────────────────────────
  function showDetailView() {
    document.getElementById("view-ranking")!.classList.add("hidden");
    document.getElementById("view-detail")!.classList.remove("hidden");
  }

  function showRankingView() {
    document.getElementById("view-detail")!.classList.add("hidden");
    document.getElementById("view-ranking")!.classList.remove("hidden");
  }

  document.getElementById("back-btn")!.addEventListener("click", showRankingView);

  // ── Start ──────────────────────────────────────────────────────────────────
  init();
</script>

<style>
  /* ── Utilities ───────────────────────────────────────────────────────────── */
  .hidden { display: none !important; }
  .muted  { color: var(--text-muted); }
  .small  { font-size: 0.78rem; }

  /* ── Page header ─────────────────────────────────────────────────────────── */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }
  .page-header h1 { font-size: 1.3rem; font-weight: 700; line-height: 1.2; }
  .subtitle       { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.15rem; }
  #last-updated   { font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; }

  /* ── Tabs ────────────────────────────────────────────────────────────────── */
  .tabs { display: flex; gap: 0.4rem; margin-bottom: 0.7rem; flex-wrap: wrap; }
  .tab {
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .tab.active, .tab:hover {
    background: var(--accent-bg);
    color: var(--accent);
    border-color: var(--accent-border);
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .legend-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .legend-item   { display: flex; align-items: center; gap: 0.3rem; }
  .legend-swatch { width: 18px; height: 3px; border-radius: 2px; flex-shrink: 0; }

  /* ── Main layout ─────────────────────────────────────────────────────────── */
  .routes-layout {
    display: grid;
    grid-template-columns: 370px 1fr;
    gap: 1rem;
    align-items: start;
  }
  @media (max-width: 860px) {
    .routes-layout { grid-template-columns: 1fr; }
  }

  /* ── Left panel shell ────────────────────────────────────────────────────── */
  .left-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    height: calc(100vh - 260px);
    min-height: 420px;
    max-height: 620px;
    display: flex;
    flex-direction: column;
  }

  /* ── Ranking view ────────────────────────────────────────────────────────── */
  #view-ranking { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

  .panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.75rem 0.35rem;
  }
  .panel-title { font-weight: 600; font-size: 0.88rem; }

  .filter-bar {
    display: flex;
    gap: 0.4rem;
    padding: 0 0.75rem 0.45rem;
    border-bottom: 1px solid var(--border);
  }
  .filter-input, .filter-select {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: var(--font);
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .filter-input  { flex: 1; min-width: 0; }
  .filter-select { flex-shrink: 0; }
  .filter-input:focus,
  .filter-select:focus       { border-color: var(--accent); }

  .routes-list {
    list-style: none;
    overflow-y: auto;
    flex: 1;
    padding: 0.25rem 0;
  }

  .list-placeholder, .list-empty, .list-error {
    padding: 2rem 1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
  }
  .list-error { color: var(--red); }

  /* ── Route cards (dynamic innerHTML — must use :global) ─────────────────── */
  :global(.route-card) {
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
    outline: none;
  }
  :global(.route-card:hover),
  :global(.route-card:focus)   { background: var(--bg-card-hover); }
  :global(.route-card.selected) {
    background: var(--accent-bg);
    border-left: 3px solid var(--accent);
    padding-left: calc(0.9rem - 3px);
  }
  :global(.route-card--inactive) {
    opacity: 0.38;
    padding-top: 0.28rem;
    padding-bottom: 0.28rem;
  }
  :global(.route-card--inactive:hover),
  :global(.route-card--inactive:focus) { opacity: 0.7; background: var(--bg-card-hover); }

  :global(.rc-top) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  :global(.rc-rank) {
    font-size: 0.67rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-sub);
    width: 1.35rem;
    text-align: right;
    flex-shrink: 0;
  }
  :global(.rc-badge) {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.67rem;
    font-weight: 700;
    color: #fff;
    background: var(--badge-bg, #6b7280);
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.01em;
  }
  :global(.rc-badge--lg) {
    font-size: 0.85rem;
    padding: 0.2rem 0.65rem;
  }
  :global(.rc-name) {
    flex: 1;
    font-size: 0.8rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.2;
    min-width: 0;
  }
  :global(.rc-pct) {
    font-size: 0.8rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  :global(.rc-bar-wrap) {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    margin: 0.22rem 0 0.18rem 1.85rem;
    overflow: hidden;
  }
  :global(.rc-bar) {
    height: 100%;
    border-radius: 2px;
    min-width: 2px;
  }
  :global(.rc-stats) {
    font-size: 0.7rem;
    color: var(--text-muted);
    padding-left: 1.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.rc-detail-link) {
    color: var(--accent);
    text-decoration: none;
    margin-left: 0.3rem;
    font-size: 0.72rem;
    opacity: 0.7;
  }
  :global(.rc-detail-link:hover) { opacity: 1; }

  /* ── Detail view ─────────────────────────────────────────────────────────── */
  #view-detail {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--accent);
    font-family: var(--font);
    width: 100%;
    text-align: left;
    transition: background 0.1s;
  }
  .back-btn:hover { background: var(--accent-bg); }

  .detail-header {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.7rem 1rem 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* detail-header innerHTML — :global needed */
  :global(.detail-name) {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .detail-stats {
    display: flex;
    border-bottom: 1px solid var(--border);
  }

  /* detail-stats innerHTML — :global needed */
  :global(.ds-item) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.5rem 0.2rem;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  :global(.ds-item:last-child) { border-right: none; }
  :global(.ds-value) {
    font-size: 1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    margin-bottom: 0.18rem;
  }
  :global(.ds-red)      { color: var(--red); }
  :global(.ds-label)    { font-size: 0.67rem; color: var(--text-muted); }
  :global(.ds-inactive) {
    padding: 0.55rem 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── Stops rail ──────────────────────────────────────────────────────────── */
  /*
   * Layout constants (keep in sync):
   *   --rail-x   : X of line center inside .stops-rail
   *   rail padding-left = --rail-x + enough room for dot + text gap
   *
   * Line left-edge = --rail-x - 1px (line is 2px wide, center = --rail-x)
   * Dot ::before uses  left: --rail-x  +  transform: translate(-50%, -50%)
   * → dot center always = --rail-x  ✓
   */
  .stops-section {
    flex: 1;
    overflow-y: auto;
  }
  .stops-label {
    font-size: 0.7rem;

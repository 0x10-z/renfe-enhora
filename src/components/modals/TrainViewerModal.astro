<!-- Train image viewer modal -->
<div id="train-viewer-modal" class="train-viewer-modal" role="dialog" aria-modal="true" aria-labelledby="train-viewer-title" style="display:none">
  <div class="train-viewer-panel">
    <button type="button" class="train-viewer-close" id="train-viewer-close" aria-label="Cerrar imagen ampliada">×</button>
    <img id="train-viewer-image" class="train-viewer-image" src="" alt="Foto aproximada de la serie de tren" loading="lazy" />
    <div class="train-viewer-info">
      <h3 id="train-viewer-title">Serie aproximada</h3>
      <p id="train-viewer-train-name" class="train-viewer-train-name">Servicio detectado: -</p>
      <p class="train-viewer-note">Renfe utiliza diferentes series de tren y esta foto es orientativa, por lo que puede no ajustarse al 100% al material exacto de cada servicio.</p>
      <p class="modal-train-preview-license">Foto tomada de Wikipedia bajo licencia <a href="https://creativecommons.org/licenses/by-sa/3.0/deed.es" target="_blank" rel="noopener noreferrer">CC BY-SA 3.0</a>.</p>
    </div>
  </div>
</div>

<!-- Insight drilldown modal -->
<div id="insight-modal" class="modal-backdrop" role="dialog" aria-modal="true" style="display:none">
  <div class="modal-panel" style="max-width:560px">
    <div class="modal-header">
      <div style="flex:1;min-width:0">
        <h2 id="insight-modal-title" style="font-size:0.95rem;font-weight:700;letter-spacing:-0.02em"></h2>
        <p class="station-meta" id="insight-modal-sub"></p>
      </div>
      <button type="button" class="modal-close" id="insight-modal-close" aria-label="Cerrar">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" id="insight-modal-body" style="padding:0.75rem;overflow-y:auto"></div>
  </div>
</div>

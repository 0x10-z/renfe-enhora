<!-- CCAA drilldown modal: shows delayed arrivals for a selected comunidad autónoma -->
<div id="ccaa-detail-modal" class="modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="ccaa-detail-title" style="display:none">
  <div class="modal-panel">
    <div class="modal-header">
      <div class="modal-title-wrap">
        <div>
          <h2 id="ccaa-detail-title">Retrasos por comunidad</h2>
          <p class="station-meta" id="ccaa-detail-meta"></p>
        </div>
      </div>
      <div class="modal-header-right">
        <div id="ccaa-detail-chips" class="summary-chips"></div>
        <button type="button" class="modal-close" id="ccaa-detail-close" aria-label="Cerrar">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <div class="modal-body">
      <div class="board-wrap">
        <table class="board">
          <thead>
            <tr>
              <th>Tren / Trayecto</th>
              <th>Tipo</th>
              <th>Estación</th>
              <th>Programada</th>
              <th>Estimada</th>
              <th>Retraso</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody id="ccaa-detail-body"></tbody>
        </table>
        <div id="ccaa-detail-empty" class="empty-state" style="display:none">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.25"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>
          <p>Sin retrasos registrados para esta comunidad en la última captura.</p>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <span id="ccaa-detail-updated" class="muted"></span>
    </div>
  </div>
</div>

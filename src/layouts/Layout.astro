---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
}

const {
  title,
  description = "Tablero en tiempo real de llegadas y retrasos de Renfe. Cercanías y AVE/Larga Distancia. Datos actualizados cada hora.",
  ogImage = "/og-preview.png",
  ogUrl = "https://enhora.info",
  ogType = "website",
} = Astro.props;

const fullTitle = `${title} · enhora.info`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <!-- OpenGraph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:url"         content={ogUrl} />
    <meta property="og:locale"      content="es_ES" />
    <meta property="og:site_name"   content="enhora.info" />
    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <!-- Canonical -->
    <link rel="canonical" href={ogUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <a href="/" class="logo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="7" width="20" height="14" rx="2"/>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          <path d="M6 7v3"/><path d="M18 7v3"/>
          <circle cx="7.5" cy="17" r="1.5"/><circle cx="16.5" cy="17" r="1.5"/>
        </svg>
        <span class="logo-text"><span class="logo-en">en</span>hora<span class="logo-tld">.info</span></span>
      </a>
      <nav class="header-nav">
        <a href="/" class="nav-link">Tablero</a>
        <a href="/rutas" class="nav-link">Rutas</a>
        <a href="/zonas" class="nav-link">Zonas</a>
        <a href="/sobre" class="nav-link">¿Cómo funciona?</a>
      </nav>
    </header>

    <!-- First-visit banner (U12) -->
    <div id="welcome-banner" class="welcome-banner" style="display:none" role="alert">
      <div class="welcome-banner-inner">
        <span class="welcome-banner-icon" aria-hidden="true">👋</span>
        <div class="welcome-banner-text">
          <strong>Bienvenido a enhora.info</strong> — datos de retrasos de Renfe actualizados cada hora. Los datos son de la última captura disponible.
        </div>
        <button class="welcome-banner-close" id="welcome-banner-close" aria-label="Cerrar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Expanded footer (U11) -->
    <footer>
      <div class="footer-expanded">
        <div class="footer-col">
          <span class="footer-col-title">enhora.info</span>
          <p>Tablero en tiempo real de retrasos de Renfe. Datos GTFS actualizados cada hora.</p>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Páginas</span>
          <nav class="footer-nav">
            <a href="/">Tablero</a>
            <a href="/rutas">Rutas</a>
            <a href="/sobre">¿Cómo funciona?</a>
          </nav>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Fuentes</span>
          <nav class="footer-nav">
            <a href="https://data.renfe.com" target="_blank" rel="noopener">Renfe Open Data</a>
            <a href="https://github.com/0x10-z/renfe-enhora" target="_blank" rel="noopener">Código en GitHub</a>
            <a href="https://ikerocio.com" target="_blank" rel="noopener">Autor: Iker Ocio</a>
          </nav>
        </div>
      </div>
      <div class="footer-bottom">
        Licencia CC BY 4.0 · Actualización cada hora · Datos: <a href="https://data.renfe.com" target="_blank" rel="noopener">Renfe Open Data</a>
      </div>
    </footer>

    <script>
      // U12: First-visit banner
      const banner = document.getElementById("welcome-banner");
      if (banner && !localStorage.getItem("enhora_visited")) {
        banner.style.display = "block";
      }
      document.getElementById("welcome-banner-close")?.addEventListener("click", () => {
        const b = document.getElementById("welcome-banner");
        if (b) b.style.display = "none";
        localStorage.setItem("enhora_visited", "1");
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f5f5f4;
    --bg-card: #ffffff;
    --bg-card-hover: #f0faf9;
    --bg-input: #ffffff;
    --border: #e4e4e7;
    --border-bright: #c4c4c8;
    --text: #111827;
    --text-muted: #52525b;
    --text-sub: #a1a1aa;
    --accent: #0d9488;
    --accent-bg: rgba(13, 148, 136, 0.08);
    --accent-border: rgba(13, 148, 136, 0.28);
    --green: #059669;
    --green-bg: rgba(5, 150, 105, 0.08);
    --green-border: rgba(5, 150, 105, 0.2);
    --yellow: #b45309;
    --yellow-bg: rgba(180, 83, 9, 0.07);
    --yellow-border: rgba(180, 83, 9, 0.2);
    --orange: #c2410c;
    --orange-bg: rgba(194, 65, 12, 0.07);
    --orange-border: rgba(194, 65, 12, 0.2);
    --red: #dc2626;
    --red-bg: rgba(220, 38, 38, 0.07);
    --red-border: rgba(220, 38, 38, 0.2);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.03);
    --shadow: 0 4px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
    --font: "Inter", system-ui, -apple-system, sans-serif;
    --font-mono: "JetBrains Mono", "Courier New", monospace;
    --radius: 10px;
    --radius-sm: 6px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    line-height: 1.55;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
  }

  header {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: var(--shadow-sm);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .logo svg { color: var(--accent); flex-shrink: 0; }
  .logo-text {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .logo-en  { color: var(--accent); font-style: italic; }
  .logo-tld { color: var(--text-sub); font-weight: 400; font-size: 0.85em; letter-spacing: 0; }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-link {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg);
  }

  main {
    flex: 1;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
  }

  /* ── Welcome banner (U12) ────────────────────────────────────────────────── */
  .welcome-banner {
    background: var(--accent-bg);
    border-bottom: 1px solid var(--accent-border);
  }
  .welcome-banner-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .welcome-banner-icon { font-size: 1.1rem; flex-shrink: 0; }
  .welcome-banner-text {
    flex: 1;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.45;
  }
  .welcome-banner-text strong { color: var(--text); }
  .welcome-banner-close {
    background: none;
    border: none;
    color: var(--text-sub);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .welcome-banner-close:hover { color: var(--text); }

  /* ── Footer ──────────────────────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    background: #fff;
  }
  .footer-expanded {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 1rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
  }
  @media (max-width: 640px) {
    .footer-expanded { grid-template-columns: 1fr; gap: 1.25rem; }
  }
  .footer-col-title {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-sub);
    margin-bottom: 0.5rem;
  }
  .footer-col p {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .footer-nav a {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--accent); }
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
    text-align: center;
    font-size: 0.7rem;
    color: var(--text-sub);
  }
  .footer-bottom a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .footer-bottom a:hover { color: var(--text); }

  h1 {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  a { color: var(--accent); }
  button { cursor: pointer; font-family: var(--font); }

  .mono { font-family: var(--font-mono); }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 3px; }
</style>
